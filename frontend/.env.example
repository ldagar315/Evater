VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Used by Netlify/Supabase functions to validate CORS origins (comma-separated).
# Configure this in your deployment environment (Netlify/Supabase), not in Vite runtime.
APP_ORIGINS=https://your-domain.example,https://staging.your-domain.example
